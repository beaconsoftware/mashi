# ── ANTHROPIC ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OPENAI ────────────────────────────────────────────────
# Used ONLY for tool-retrieval embeddings (text-embedding-3-small) in
# src/lib/embeddings/openai.ts. Powers Phase 6 of the agent quality
# upgrade. Without it the agent loop falls back to shipping the full
# ring-filtered tool pool every turn — works, just less token-efficient.
OPENAI_API_KEY=

# ── SUPABASE ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── GOOGLE (OAuth + Gmail + Calendar + Drive) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ── MICROSOFT (OAuth + Outlook + Calendar) ────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=common

# ── SLACK ─────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# ── FIREFLIES ─────────────────────────────────────────────
FIREFLIES_API_KEY=

# ── LINEAR ────────────────────────────────────────────────
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# ── SPOTIFY ───────────────────────────────────────────────
# Dashboard: https://developer.spotify.com/dashboard
# Redirect URI: <APP_URL>/api/connect/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── VOYAGE AI (embeddings) ────────────────────────────────
VOYAGE_API_KEY=

# ── INNGEST (background jobs) ─────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── RESEND (email delivery for briefings) ─────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── APP ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 1 to expose the agent thread's internal "Replay / debug" panel (J3):
# shows the reconstructed Anthropic message list a turn ran with and offers a
# re-run. Leave unset/empty in normal use; it renders nothing.
NEXT_PUBLIC_AGENT_DEBUG=

# ── ENCRYPTION (for tokens at rest) ───────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── GITHUB (Mac helper .dmg proxy) ────────────────────────
# GitHub PAT used by /api/downloads/mac-helper to fetch the latest .dmg
# release asset from a private repo. Only `repo` scope is required; the
# proxy uses it solely to authenticate the asset stream. Generate at
# https://github.com/settings/tokens/new with the `repo` scope and set
# in Vercel project env. Not needed in local dev unless you're testing
# the download endpoint.
GITHUB_DOWNLOAD_TOKEN=

# ── CRON (auto-sync) ──────────────────────────────────────
# Required for /api/sync/all (the Vercel cron entrypoint). Vercel sends
# `Authorization: Bearer $CRON_SECRET` to the cron path; the route refuses
# to run if this is unset. Set in the Vercel project settings — production
# only, not needed in local dev.
# Generate with: openssl rand -hex 32
CRON_SECRET=
