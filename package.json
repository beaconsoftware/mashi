{
  "name": "mashi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL; next dev",
    "build": "unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL; next build",
    "start": "unset ANTHROPIC_API_KEY ANTHROPIC_BASE_URL; next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "audit:layers": "bash scripts/audit-layers.sh",
    "audit:translucency": "bash scripts/audit-translucency.sh",
    "audit:motion": "bash scripts/audit-motion.sh",
    "test:visual": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "test:hooks": "tsx src/lib/agent/hooks/__tests__/runner.test.ts",
    "test:replay": "tsx src/lib/agent/__tests__/replay.test.ts",
    "test:pricing": "tsx src/lib/anthropic/__tests__/pricing.test.ts",
    "test:retry": "tsx src/lib/agent/__tests__/retry.test.ts",
    "test:budget": "tsx src/lib/agent/__tests__/budget.test.ts",
    "test:provenance": "tsx src/lib/agent/__tests__/provenance.test.ts",
    "test:transcript": "tsx src/lib/agent/__tests__/conversation-control.test.ts",
    "test:attachments": "tsx src/lib/agent/__tests__/attachments.test.ts",
    "test:references": "tsx src/lib/agent/__tests__/references.test.ts",
    "test:approval-meta": "tsx src/lib/agent/__tests__/approval-meta.test.ts",
    "test:policy": "tsx src/lib/agent/__tests__/policy.test.ts",
    "test:tool-meta": "tsx src/lib/agent/__tests__/tool-meta.test.ts",
    "embed-tools": "tsx scripts/embed-tools.ts",
    "check:embeddings": "tsx scripts/embed-tools.ts --check",
    "verify": "pnpm typecheck && pnpm lint && pnpm audit:layers && pnpm audit:translucency && pnpm audit:motion && pnpm check:embeddings && pnpm test:pricing && pnpm test:retry && pnpm test:budget && pnpm test:provenance && pnpm test:transcript && pnpm test:attachments && pnpm test:references && pnpm test:approval-meta && pnpm test:policy && pnpm test:tool-meta"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
