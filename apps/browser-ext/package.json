{
  "name": "mashi-browser-ext",
  "version": "0.1.0",
  "private": true,
  "description": "Mashi Activity Watcher — Chromium MV3 extension. Emits tab focus heartbeats to your Mashi instance.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "typescript": "^5.6.3"
  }
}
