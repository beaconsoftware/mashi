{
  "manifest_version": 3,
  "name": "Mashi Activity Monitor",
  "version": "0.1.0",
  "description": "Sends tab focus signals to Mashi so it can suggest task state changes. Captures only URL + title + timestamp; never page content.",
  "permissions": ["tabs", "storage", "notifications", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "options_page": "src/options.html",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Mashi Activity Monitor"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "mashi-activity-watcher@beaconsoftware.com",
      "strict_min_version": "121.0"
    }
  }
}
